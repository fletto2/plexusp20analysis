#  
# @(#)dumber	1.1 12/11/85 

# lp interface for dumber line printer raw device
#
#	SCCS @(#)dumb	1.1

user=`grep "^$2:" /etc/passwd | line | cut -d: -f5`
copies=$4
shift; shift; shift; shift; shift
files="$*"
i=1
while [ $i -le $copies ]
do
	for file in $files
	do
		/etc/wbs < "$file"
	done
	i=`expr $i + 1`
done
exit 0
