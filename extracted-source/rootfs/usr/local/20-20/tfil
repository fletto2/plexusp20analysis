;====================================================================
;
;             ********  PLOTTER DEFINITIONS ********
;
;
; To enable the appropriate ones, copy the appropriate device definition
; to the DEVICE section at the top of the file.  Remove the semicolons from 
; the start of each line of the entry.  Don't forget to disable the
; ones being replaced.
;
; There is a maximum of four (4) enabled  plotter definitions.  Remember to 
; check the 20/20 logical device  names (between the IS and the ON) for 
; conflicts -- the enabled devices must have unique names.
;
;====================================================================
;                   ****  HP7475A Entries ****
;====================================================================
;
; ** For making offline plots, the port name is a dummy.
;    Device definitions are set to default to "A" sized paper.
;    If "B" is installation standard, change to ph = 11 and pw = 17
;
;=====================================================================
; * HP7475A with XON/XOFF, offline plots.
;
; DEVICE HP7475A IS hp6off ON PORT /dev/null
;        ph = 8.5
;        pw = 11
;        is = \033.Y\033.R\033.@1024;0:\033.I80;;17:\033.N;19:
;        ts = \033.Z
;        of = offline
;=====================================================================
; * HP7475A with hardwire handshake, offline plots.
;
; DEVICE HP7475A IS hp6off ON PORT /dev/null
;        ph = 8.5
;        pw = 11
;        is = \033.Y\033.R\033.@1024;1:
;        ts = \033.Z
;        of = offline
;=====================================================================
; * HP7475A with communications already set up, offline plots.
;
; DEVICE HP7475A IS hp6off ON PORT /dev/null
;        ph = 8.5
;        pw = 11
;        is = \033.Y
;        ts = \033.Z
;        of = offline
;=====================================================================
;
; **** Normal on-line HP7475A plotter entries.  Plotter has its own port,
;      which is ASSIGNed to plot001.  Any setup necessary is done from
;      the command file.
;=====================================================================
; * HP7475A with allocated plotter port, online plots, and 
;   XON/XOFF line control.
;
; DEVICE HP7475A IS hp6on ON PORT /dev/plot
;        is = \033.Y\033.J\033.K\033.R\033.@1024;0:\033.I80;;17:\033.N;19:
;        ts = \033.Z
;        ph = 8.5
;        pw = 11
;=====================================================================
; * HP7475A with allocated plotter port, online plots, and 
;   hardwire handshake line control.
;
; DEVICE HP7475A IS hp6on ON PORT /dev/plot
;        is = \033.Y\033.R\033.@1024;1:
;        ts = \033.Z
;        ph = 8.5
;        pw = 11
;=====================================================================
; ** On-line HP7475A plotter being driven through an eavesdrop cable.
;    Uses XON/XOFF line control.
;
; DEVICE HP7475A IS hp6on ON PORT /dev/tty
;        ph = 8.5
;        pw = 11
;        is = \033.Y\033.J\033.K\033.R\033.@1024;0:\033.I80;;17:\033.N;19:
;        ts = \033.Z
;=====================================================================
; ** On-line HP7475A plotter being driven through an eavesdrop cable.
;    Uses hardwire handshake line control.
;
; DEVICE HP7475A IS hp6on ON PORT /dev/tty
;        ph = 8.5
;        pw = 11
;        is = \033.Y\033.J\033.K\033.RDF;SP0;PU;
;        ts = \033.Z
;=====================================================================
; ** On-line HP7475A plotter being driven through a VT-125 
;    printer port.  Uses XON/XOFF line control.
;
; DEVICE HP7475A IS hp6on ON PORT /dev/tty
;        ph = 8.5
;        pw = 11
;        is = \033[5i\033[6i\033.Y\033.J\033.K\033.R\033.@1024;0:\033.I80;;17:\033.N;19:
;        ts = \033.Z\033[7i\033[4i
;=====================================================================
; ** On-line HP7475A plotter being driven through a VT-125 
;    printer port.  Uses hardwire handshake line control.
;
; DEVICE HP7475A IS hp6on ON PORT /dev/tty
;        ph = 8.5
;        pw = 11
;        is = \033[5i\033[6i\033.Y\033.J\033.K\033.R\033.@1024;1:
;        ts = \033.Z\033[7i\033[4i
;=====================================================================
; ** On-line HP7475A plotter being driven through a VT-240 
;    printer port.    Uses XON/XOFF line control.
;
; DEVICE HP7475A IS hp6on ON PORT /dev/tty
;        ph = 8.5
;        pw = 11
;        is = \033[5i\033.Y\033.J\033.K\033.R\033.@1024;0:\033.I80;;17:\033.N;19:
;        ts = \033.Z\033[4i
;=====================================================================
; ** On-line HP7475A plotter being driven through a VT-240 
;    printer port.   Uses hardwire handshake line control.
;
; DEVICE HP7475A IS hp6on ON PORT /dev/tty
;        ph = 8.5
;        pw = 11
;        is = \033[5i\033.Y\033.J\033.K\033.R\033.@1024;1:
;        ts = \033.Z\033[4i
;=====================================================================
; ** On-line Decwriter (LA-50 and LA-100) files
;    The Decwriter must be plugged into the terminal's printer
;    port.  The terminal is assumed to be the user's terminal.
;=====================================================================
; * LA-50 plugged into a VT-125.  Maximum chart width is 5.33 inches.
; DEVICE VT1LA50 IS decwon ON PORT /dev/tty
;        ph = 3.33
;        pw = 5.33
;=====================================================================
; * LA-50 plugged into a VT-240.  Maximum chart width is 5.55 inches.
; DEVICE VT2LA50 IS decwon ON PORT /dev/tty
;        ph = 3.33
;        pw = 5.55
;=====================================================================
; * LA-100 plugged into a VT-125.  Maximum chart width is 5.82 inches.
; DEVICE VT1LA100 IS decwon ON PORT /dev/tty
;        ph = 3.33
;        pw = 5.82
; * LA-100 plugged into a VT-240.  Maximum chart width is 6.06 inches.
; DEVICE VT2LA100 IS decwon ON PORT /dev/tty
;        ph = 3.33
;        pw = 6.06
