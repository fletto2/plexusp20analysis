!DEVICES
;=====================================================================
;
;          See directions for defining plotters following the final 
;          terminal entry, below.
;
;=====================================================================
; * HP7475A with XON/XOFF, offline plots.
;
 DEVICE HP7475A IS 6PEN_OFF ON PORT /dev/null
        ph = 8.5
        pw = 11.0
        is = \033.Y\033.R\033.@1024;0:\033.I80;;17:\033.N;19:
        ts = \033.Z
        of = offline
;=====================================================================
; * HP7475A with allocated plotter port, online plots, and 
;   XON/XOFF line control.
;
 DEVICE HP7475A IS 6PEN_ON ON PORT /dev/plot
        is = \033.Y\033.J\033.K\033.R\033.@1024;0:\033.I80;;17:\033.N;19:
        ts = \033.Z
        ph = 8.5
        pw = 11.0
;=====================================================================
; * LA-100 via VT-125.  Maximum chart width is 5.82 inches.
;   Offline plot file is created.
;
 DEVICE VT1LA100 IS LA100_OFF ON PORT /dev/tty
        ph = 3.33
        pw = 5.82
        of = offline
;=====================================================================
; * LA-50 plugged into a VT-125.  Maximum chart width is 5.33 inches.
 DEVICE VT1LA50 IS LA50_ON ON PORT /dev/tty
        ph = 3.33
        pw = 5.33
!
