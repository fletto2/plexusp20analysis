BASE=/usr/local/20-20
TARGET=2020V13

SuTERM=vt100			# default terminal type
SuTFIL=${BASE}/tfil		# terminal database
SuHFIL=${BASE}/hfil		# help file (table of contents)
SuMEMR=100000			# maximum model size
SuPRLN=60			# printer page length
SuPRWD=80			# printer page width
SuPRDF='|lp'			# printer spooler
export SuTERM SuTFIL SuHFIL SuPRLN SuPRWD SuPRDF SuMEMR
stty -echo raw ixon
${BASE}/${TARGET} $@
stty echo -raw 
